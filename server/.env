PORT=5000

# MongoDB URI (default to a local Mongo database called sample-app)
MONGO_URI=mongodb://127.0.0.1:27017/sample-app

# Bypass Firebase Admin token verification for easy local setup/testing.
# Set to 'false' if using a real Firebase Service Account Key.
BYPASS_FIREBASE_VERIFICATION=true

# Path to the Firebase service account JSON key file (if not bypassing)
# Example: FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=
